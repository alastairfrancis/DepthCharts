{
  "name": "[UAT] TxO BKB IP Pricing - Multibet 403 and 5xx errors",
  "type": "log alert",
  "query": "container_name:bb-uat-uks-txo-bkb-ip-pricing \"Txo Multibet price request failed\" (\"code: 403\" OR \"code: 5\")",
  "message": "TxO Multibet price request failures (403 or 5xx) detected in bb-uat-uks-txo-bkb-ip-pricing.\n\nLog format: Txo Multibet price request failed, {Legs} code: {statusCode} message: {message}\n\n@slack-ops",
  "tags": ["env:uat", "service:txo-bkb-ip-pricing", "team:txo"],
  "priority": 3,
  "options": {
    "thresholds": {
      "critical": 1,
      "warning": 0
    },
    "enable_logs_sample": true,
    "groupby_simple_monitor": true,
    "notify_audit": false,
    "notify_no_data": false,
    "include_tags": true,
    "new_group_delay": 60,
    "evaluation_delay": 0,
    "no_data_timeframe": 10,
    "renotify_interval": 0,
    "escalation_message": "",
    "require_full_window": true,
    "silenced": {}
  }
}
